# MySQL 数据库连接
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=pieceabean

# JWT 密钥
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 应用配置
APP_NAME=拼豆 PieceABean
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
